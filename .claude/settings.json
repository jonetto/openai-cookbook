{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash plugins/doc-sync/hooks/discover-related-docs.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
